---
import '@fontsource-variable/inter';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  lcpImage?: string;
}

const {
  title,
  description = "Honest GPS dog fence reviews and comparisons. Find the best GPS dog fence for your property with our in-depth, hands-on testing.",
  canonical,
  ogImage = "https://betterthanafence.com/wp-content/uploads/2025/05/SpotOn-Collar-on-Box-Landscape-Crop.jpg",
  lcpImage,
} = Astro.props;

const siteTitle = title === "Home" ? "Better Than A Fence | GPS Dog Fence Reviews & Comparisons" : `${title} | Better Than A Fence`;

// Auto-generate canonical URL (override with canonical prop if provided)
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;

// Sitewide Organization schema
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Better Than A Fence",
  "url": "https://betterthanafence.com",
  "logo": "https://betterthanafence.com/wp-content/uploads/2025/05/%E2%80%8EBetter-Than-A-Fence-Logo.png",
  "description": "Honest GPS dog fence reviews and comparisons from a real dog owner who spent $5,200+ testing every system.",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "contact@betterthanafence.com",
    "contactType": "customer service"
  }
};

// Breadcrumb schema (non-homepage pages only)
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const isHomepage = pathSegments.length === 0;
const breadcrumbSchema = !isHomepage ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://betterthanafence.com/" },
    { "@type": "ListItem", "position": 2, "name": title, "item": canonicalUrl }
  ]
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="https://betterthanafence.com/wp-content/uploads/2025/05/%E2%80%8EBetter-Than-A-Fence-Logo.png" />

    <!-- Fonts: self-hosted via @fontsource-variable/inter (no external requests) -->

    <!-- DNS prefetch for deferred third-party scripts -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <link rel="dns-prefetch" href="https://www.clarity.ms" />
    <link rel="dns-prefetch" href="https://deals.betterthanafence.com" />

    <!-- LCP image preload -->
    {lcpImage && <link rel="preload" as="image" href={lcpImage} />}

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data: Organization (sitewide) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- CTA Click Tracking — GA4 + Meta Pixel -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var el = e.target.closest('[data-cta-label]');
        if (!el) return;
        var label = el.getAttribute('data-cta-label');
        var brand = el.getAttribute('data-cta-brand') || 'unknown';
        var page = document.location.pathname.replace(/^\/|\/$/g, '') || 'home';
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', {
            cta_label: label,
            cta_brand: brand,
            cta_page: page
          });
        }
        if (typeof fbq === 'function') {
          fbq('trackCustom', 'CTAClick', {
            cta_label: label,
            cta_brand: brand,
            cta_page: page
          });
        }
      });
    </script>

    <!-- Deferred Tracking Scripts — loads after page is interactive -->
    <script is:inline>
      (function() {
        function loadTracking() {
          // Google Analytics GA4
          var g = document.createElement('script');
          g.src = 'https://www.googletagmanager.com/gtag/js?id=G-14204522982';
          document.head.appendChild(g);
          g.onload = function() {
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', 'G-14204522982');
          };

          // Meta Pixel
          !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){
          n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};
          if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
          n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];
          s.parentNode.insertBefore(t,s)}(window,document,'script',
          'https://connect.facebook.net/en_US/fbevents.js');
          fbq('init', '1917597695457820');
          fbq('track', 'PageView');

          // Microsoft Clarity
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window,document,"clarity","script","qf0mlll7rc");

          // Redtrack
          var r = document.createElement('script');
          r.src = 'https://deals.betterthanafence.com/unilpclick.js?attribution=lastpaid&cookiedomain=&cookieduration=90&defaultcampaignid=&regviewonce=false';
          document.head.appendChild(r);
        }

        // Load on idle with 3s max fallback
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadTracking, { timeout: 3000 });
        } else {
          setTimeout(loadTracking, 2000);
        }
      })();
    </script>

    <!-- Meta Pixel noscript fallback -->
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1917597695457820&ev=PageView&noscript=1" /></noscript>
  </body>
</html>
