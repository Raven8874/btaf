---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="After spending $5,200+ testing every GPS dog fence on the market, I found the one that actually works. Read honest, hands-on reviews from a real dog owner." lcpImage="/images/SpotOn-Collar-on-Box-Landscape-Crop.jpg">

  <!-- WebSite schema (homepage only) -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Better Than A Fence",
    "url": "https://betterthanafence.com",
    "description": "Honest GPS dog fence reviews and comparisons from a real dog owner who spent $5,200+ testing every system."
  }
  </script>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="badge badge-orange">Trusted by 3,400+ Dog Owners</span>
          <h1>The Only GPS Dog Fence Reviews You Can Trust</h1>
          <p class="hero-sub">After spending <strong>$5,200+ testing 8+ GPS dog fences</strong> on a real property with trees, buildings, and every GPS challenge imaginable — I'll show you which ones actually keep your dog safe.</p>
          <div class="hero-ctas">
            <a href="/spoton-vs-halo" class="btn btn-primary btn-lg">Read the #1 Comparison</a>
            <a href="/spoton-gps-dog-fence-discount-save-80-today" class="btn btn-secondary btn-lg" data-cta-label="hero-secondary" data-cta-brand="spoton">Get $80 Off SpotOn</a>
          </div>
          <div class="hero-trust">
            <div class="trust-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 1l2.39 4.84L17.82 6.5l-3.91 3.81.92 5.39L10 13.26l-4.83 2.54.92-5.39L2.18 6.6l5.43-.76L10 1z" fill="#F97316"/></svg>
              <span>14+ Months of Testing</span>
            </div>
            <div class="trust-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 1l2.39 4.84L17.82 6.5l-3.91 3.81.92 5.39L10 13.26l-4.83 2.54.92-5.39L2.18 6.6l5.43-.76L10 1z" fill="#F97316"/></svg>
              <span>1,900+ Reviews Analyzed</span>
            </div>
            <div class="trust-item">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 1l2.39 4.84L17.82 6.5l-3.91 3.81.92 5.39L10 13.26l-4.83 2.54.92-5.39L2.18 6.6l5.43-.76L10 1z" fill="#F97316"/></svg>
              <span>Zero Sponsored Reviews</span>
            </div>
          </div>
        </div>
        <div class="hero-image">
          <img src="/images/SpotOn-Collar-on-Box-Landscape-Crop.jpg" alt="SpotOn GPS Dog Fence on product box" width="1024" height="682" fetchpriority="high" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- TOP PICK BANNER -->
  <section class="top-pick">
    <div class="container">
      <div class="top-pick-card">
        <div class="top-pick-badge">Our #1 Pick</div>
        <div class="top-pick-inner">
          <img src="/images/SpotOn-In-Hand-Crop.jpeg" alt="SpotOn GPS Fence in hand" class="top-pick-img" width="600" height="400" loading="lazy" decoding="async" />
          <div class="top-pick-info">
            <h2>SpotOn Nova</h2>
            <div class="top-pick-rating">
              <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
              <span class="rating-text">4.8/5 &mdash; Best Overall GPS Dog Fence</span>
            </div>
            <ul class="top-pick-features">
              <li>Works 100% off-grid — no cellular required for fencing</li>
              <li>Under 5 ft accuracy — 99.3% containment rate</li>
              <li>No mandatory subscription — pay once, use forever</li>
              <li>90-day risk-free trial &amp; free trainer consultation</li>
            </ul>
            <a href="https://deals.betterthanafence.com/click" class="btn btn-primary" data-cta-label="top-pick-card" data-cta-brand="spoton" target="_blank" rel="noopener noreferrer nofollow">Get SpotOn Nova ($80 Off) &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED REVIEWS -->
  <section class="section reviews-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="badge badge-orange">In-Depth Reviews</span>
        <h2>Honest, Hands-On GPS Fence Reviews</h2>
        <p class="section-sub">Every review is based on months of real-world testing on a challenging 5-acre property with dense trees, metal buildings, and a busy road nearby.</p>
      </div>

      <div class="reviews-grid">
        <a href="/spoton-vs-halo" class="review-card card">
          <div class="review-card-img">
            <img src="/images/Collie-sniffing-both-collars-resize-1024x682.jpg" alt="Dog with SpotOn and Halo collars" width="1024" height="682" loading="lazy" decoding="async" />
            <span class="review-card-badge">Most Popular</span>
          </div>
          <div class="review-card-body">
            <h3>SpotOn vs Halo Collar: The Ultimate GPS Dog Fence Showdown</h3>
            <p>I tested both systems for 8 weeks on the same property. One system outperformed the other in 6 out of 7 key areas.</p>
            <span class="review-card-link">Read Full Comparison &rarr;</span>
          </div>
        </a>

        <a href="/spoton-nova-review" class="review-card card">
          <div class="review-card-img">
            <img src="/images/SpotOn-Collar-With-Quick-Start-Guide-Resize-1024x682.jpg" alt="SpotOn collar with quick start guide" width="1024" height="682" loading="lazy" decoding="async" />
          </div>
          <div class="review-card-body">
            <h3>SpotOn GPS Dog Fence Review: The Good, Bad &amp; Ugly Truth</h3>
            <p>14 months of daily use in every condition imaginable. Here's everything — the good, the bad, and the honest truth.</p>
            <span class="review-card-link">Read Full Review &rarr;</span>
          </div>
        </a>

        <a href="/halo-collar-5-review" class="review-card card">
          <div class="review-card-img">
            <img src="/images/Halo-Collar-With-Box-Landscape-Crop.jpeg" alt="Halo Collar 5 with box" width="1024" height="682" loading="lazy" decoding="async" />
          </div>
          <div class="review-card-body">
            <h3>Halo Collar 5 Review: Freedom Without Fences? The Brutal Truth</h3>
            <p>11 months of testing with two different dogs across three properties. Including the critical flaws most reviewers won't tell you.</p>
            <span class="review-card-link">Read Full Review &rarr;</span>
          </div>
        </a>

        <a href="/best-gps-dog-fence" class="review-card card">
          <div class="review-card-img">
            <img src="/images/Collie-Looking-At-Owner-Resize-1024x682.jpg" alt="Border Collie looking at owner" width="1024" height="682" loading="lazy" decoding="async" />
          </div>
          <div class="review-card-body">
            <h3>The $5,200 Mistake That Led Me to the Only GPS Dog Fence Worth Buying</h3>
            <p>I tested 8+ GPS fences so you don't have to. Here's the one I trust with my own dog's life.</p>
            <span class="review-card-link">Read Full Story &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- COMPARISON SNAPSHOT -->
  <section class="comparison-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="badge badge-green">Quick Comparison</span>
        <h2>SpotOn Nova vs Halo 5 at a Glance</h2>
      </div>
      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Feature</th>
              <th class="highlight-col">SpotOn Nova</th>
              <th>Halo Collar 5</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>GPS Accuracy</td>
              <td class="highlight-col"><strong>Under 5 ft</strong> (99.3% containment)</td>
              <td>2-3m open sky; drifts under trees</td>
            </tr>
            <tr>
              <td>Subscription Required?</td>
              <td class="highlight-col"><strong>No</strong> (optional tracking)</td>
              <td>Yes &mdash; $9.99+/mo</td>
            </tr>
            <tr>
              <td>Works Offline?</td>
              <td class="highlight-col"><strong>Yes</strong></td>
              <td>Requires LTE</td>
            </tr>
            <tr>
              <td>3-Year Total Cost</td>
              <td class="highlight-col"><strong>$999</strong></td>
              <td>$959 &ndash; $1,319+</td>
            </tr>
            <tr>
              <td>Return Policy</td>
              <td class="highlight-col"><strong>90-day Five Star Guarantee</strong></td>
              <td>90-day (up to 120 days w/ support)</td>
            </tr>
            <tr>
              <td>Battery Life</td>
              <td class="highlight-col"><strong>33+ hrs (with tracking)</strong></td>
              <td>Up to 48 hrs</td>
            </tr>
            <tr>
              <td>Made In</td>
              <td class="highlight-col"><strong>USA</strong></td>
              <td>Overseas</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="text-center" style="margin-top: 32px;">
        <a href="/spoton-vs-halo" class="btn btn-primary btn-lg">See Full Head-to-Head Comparison &rarr;</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section testimonials-section">
    <div class="container">
      <div class="section-header text-center">
        <h2>What Real Dog Owners Say</h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"After my dog escaped our invisible fence for the third time, I switched to SpotOn. The accuracy is mind-blowing &mdash; even in our heavily wooded backyard. It's been 6 months without a single escape."</p>
          <div class="testimonial-author">&mdash; Jennifer M., SpotOn Owner</div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"Best investment for our two Labs! The GPS fence works perfectly on our 5-acre property. Setup was easy and the discount made it a no-brainer."</p>
          <div class="testimonial-author">&mdash; Sarah J., Austin TX</div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
          <p>"The Halo's training system is incredible. My stubborn German Shepherd learned boundaries in just 5 days! The app is super intuitive, but I wish it worked better in the woods."</p>
          <div class="testimonial-author">&mdash; Michael T., Halo Owner</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="container text-center">
      <h2>Ready to Give Your Dog Freedom AND Safety?</h2>
      <p>Don't wait until after a scary escape or close call. SpotOn is the #1 GPS dog fence for accuracy, reliability, and value.</p>
      <div class="final-cta-buttons">
        <a href="https://deals.betterthanafence.com/click" class="btn btn-primary btn-lg" data-cta-label="final-cta" data-cta-brand="spoton" target="_blank" rel="noopener noreferrer nofollow">Get $80 Off SpotOn Nova &rarr;</a>
        <a href="/spoton-nova-review" class="btn btn-secondary btn-lg">Read Our Full Review</a>
      </div>
      <p class="final-cta-note">90-Day Money Back Guarantee &middot; No Subscription Required &middot; Made in the USA</p>
    </div>
  </section>

</Layout>

<style>
  .hero {
    padding: 60px 0 80px;
    background: linear-gradient(180deg, var(--off-white) 0%, var(--white) 100%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-content h1 {
    font-size: 2.75rem;
    line-height: 1.15;
    margin: 16px 0 20px;
    letter-spacing: -0.02em;
  }
  .hero-sub {
    font-size: 1.125rem;
    color: var(--gray-600);
    line-height: 1.7;
    margin-bottom: 28px;
  }
  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    color: var(--gray-500);
    font-weight: 500;
  }
  .hero-image img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    width: 100%;
  }
  @media (max-width: 768px) {
    .hero { padding: 40px 0 48px; }
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .hero-content h1 { font-size: 2rem; }
    .hero-image { order: -1; }
  }
  @media (max-width: 480px) {
    .hero-content h1 { font-size: 1.625rem; }
    .hero-sub { font-size: 1rem; }
  }

  .top-pick { padding: 0 0 60px; margin-top: -20px; }
  .top-pick-card {
    background: var(--white);
    border: 2px solid var(--orange-500);
    border-radius: var(--radius-lg);
    padding: 40px;
    position: relative;
    box-shadow: 0 8px 30px rgba(249, 115, 22, 0.12);
  }
  .top-pick-badge {
    position: absolute;
    top: -14px;
    left: 32px;
    background: linear-gradient(135deg, var(--orange-500), var(--orange-600));
    color: var(--white);
    font-weight: 700;
    font-size: 0.8125rem;
    padding: 6px 20px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .top-pick-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 36px;
    align-items: center;
  }
  .top-pick-img { border-radius: var(--radius-md); width: 100%; }
  .top-pick-rating { display: flex; align-items: center; gap: 10px; margin: 8px 0 16px; }
  .stars { color: var(--orange-500); font-size: 1.25rem; letter-spacing: 2px; }
  .rating-text { font-size: 0.875rem; color: var(--gray-500); font-weight: 500; }
  .top-pick-features { list-style: none; padding: 0; margin: 0 0 24px; }
  .top-pick-features li {
    padding: 6px 0 6px 28px;
    position: relative;
    font-size: 0.9375rem;
    color: var(--gray-700);
  }
  .top-pick-features li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--green-500);
    font-weight: 700;
  }
  @media (max-width: 768px) {
    .top-pick-card { padding: 32px 24px; }
    .top-pick-inner { grid-template-columns: 1fr; gap: 24px; }
    .top-pick-img { max-width: 240px; }
  }

  .section-header { margin-bottom: 48px; }
  .section-header h2 { margin-top: 12px; }
  .section-sub {
    color: var(--gray-500);
    font-size: 1.0625rem;
    max-width: 640px;
    margin: 12px auto 0;
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }
  .review-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .review-card:hover { color: inherit; }
  .review-card-img {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/2;
  }
  .review-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .review-card:hover .review-card-img img { transform: scale(1.05); }
  .review-card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--orange-500);
    color: var(--white);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 5px 12px;
    border-radius: 100px;
  }
  .review-card-body {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .review-card-body h3 { font-size: 1.125rem; margin-bottom: 8px; line-height: 1.4; }
  .review-card-body p {
    font-size: 0.9375rem;
    color: var(--gray-500);
    line-height: 1.6;
    flex: 1;
  }
  .review-card-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--orange-600);
    margin-top: 12px;
  }
  @media (max-width: 768px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }

  .comparison-section { padding: 80px 0; background: var(--off-white); }
  .comparison-table-wrap { overflow-x: auto; }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .comparison-table thead th {
    padding: 18px 24px;
    font-size: 0.9375rem;
    background: var(--gray-900);
    color: var(--white);
    font-weight: 600;
    text-align: left;
  }
  .comparison-table thead th.highlight-col { background: var(--orange-600); }
  .comparison-table tbody td {
    padding: 16px 24px;
    border-bottom: 1px solid var(--gray-100);
    font-size: 0.9375rem;
  }
  .comparison-table tbody td.highlight-col { background: rgba(249, 115, 22, 0.04); }
  .comparison-table tbody tr:last-child td { border-bottom: none; }
  @media (max-width: 768px) {
    .comparison-section { padding: 48px 0; }
    .comparison-table thead th,
    .comparison-table tbody td { padding: 12px 14px; font-size: 0.8125rem; }
  }

  .testimonials-section { background: var(--white); }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .testimonial-card {
    background: var(--off-white);
    border-radius: var(--radius-lg);
    padding: 28px;
    border: 1px solid var(--gray-100);
  }
  .testimonial-stars { color: var(--orange-500); font-size: 1.125rem; letter-spacing: 2px; margin-bottom: 12px; }
  .testimonial-card p {
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 16px;
  }
  .testimonial-author { font-size: 0.8125rem; font-weight: 600; color: var(--gray-800); }
  @media (max-width: 768px) {
    .testimonials-grid { grid-template-columns: 1fr; }
  }

  .final-cta { padding: 80px 0; background: linear-gradient(180deg, var(--white) 0%, var(--off-white) 100%); }
  .final-cta h2 { font-size: 2rem; margin-bottom: 12px; }
  .final-cta > .container > p {
    color: var(--gray-600);
    font-size: 1.0625rem;
    max-width: 560px;
    margin: 0 auto 28px;
  }
  .final-cta-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .final-cta-note { font-size: 0.8125rem; color: var(--gray-400); font-weight: 500; }
  @media (max-width: 768px) {
    .final-cta { padding: 48px 0; }
    .final-cta h2 { font-size: 1.5rem; }
  }
</style>
