  }
  .product-price-amount {
    font-size: 2rem;
    font-weight: 800;
    color: var(--gray-900);
  }
  .product-price-note {
    display: block;
    font-size: 0.75rem;
    color: var(--gray-400);
    margin-top: 2px;
  }
  .product-price-warn {
    display: block;
    font-size: 0.75rem;
    color: var(--orange-600);
    font-weight: 600;
    margin-top: 2px;
  }
  @media (max-width: 768px) {
    .products-grid { grid-template-columns: 1fr; max-width: 420px; }
  }

  /* ====== STORY SECTION ====== */
  .story-section {
    padding: 64px 0;
    background: var(--off-white);
  }
  .story-section img {
    border-radius: var(--radius-lg);
    margin: 24px 0;
  }
  .cost-breakdown {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 24px 0;
  }
  .cost-tier {
    border-radius: var(--radius-md);
    padding: 20px 24px;
    border-left: 4px solid;
  }
  .cost-tier h4 {
    font-size: 1rem;
    margin-bottom: 6px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  .cost-tier p { font-size: 0.9375rem; color: var(--gray-600); margin: 0; line-height: 1.6; }
  .cost-tier ul { padding-left: 1.2rem; margin: 8px 0 0; }
  .cost-tier li { font-size: 0.9375rem; color: var(--gray-600); line-height: 1.6; margin-bottom: 2px; }
  .cost-tier-total {
    font-size: 0.8125rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 100px;
  }
  .cost-tier-bad {
    background: rgba(239, 68, 68, 0.04);
    border-color: var(--red-500);
  }
  .cost-tier-bad .cost-tier-total { background: rgba(239, 68, 68, 0.1); color: var(--red-500); }
  .cost-tier-mid {
    background: rgba(249, 115, 22, 0.04);
    border-color: var(--orange-500);
  }
  .cost-tier-mid .cost-tier-total { background: rgba(249, 115, 22, 0.1); color: var(--orange-600); }
  .cost-tier-good {
    background: rgba(34, 197, 94, 0.04);
    border-color: var(--green-500);
  }
  .cost-tier-good .cost-tier-total { background: rgba(34, 197, 94, 0.1); color: var(--green-600); }
  .total-damage {
    text-align: center;
    padding: 20px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    margin: 24px 0;
  }
  .total-damage span { display: block; font-size: 0.875rem; color: var(--gray-500); }
  .total-damage strong { font-size: 2.5rem; font-weight: 800; color: var(--red-500); display: block; margin: 4px 0; }
  .price-note {
    font-size: 0.8125rem;
    color: var(--gray-400);
    font-style: italic;
  }

  /* ====== INLINE CTA ====== */
  .inline-cta { padding: 0; }
  .inline-cta-box {
    background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
    border: 1px solid #FED7AA;
    border-radius: var(--radius-lg);
    padding: 28px 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    max-width: 900px;
    margin: 0 auto;
  }
  .inline-cta-content h3 {
    font-size: 1.125rem;
    margin-bottom: 4px;
  }
  .inline-cta-content p {
    font-size: 0.875rem;
    color: var(--gray-500);
    margin: 0;
  }
  .inline-cta-proof {
    font-size: 0.8125rem;
    color: var(--orange-600);
    font-weight: 500;
    margin-top: 2px;
  }
  @media (max-width: 768px) {
    .inline-cta-box {
      flex-direction: column;
      text-align: center;
      padding: 24px;
    }
  }

  /* ====== FACTORS / REVIEWS ====== */
  .factors-section { padding: 64px 0 0; }
  .reviews-section { padding: 0 0 48px; }
  .factors-section .prose,
  .reviews-section .prose { max-width: 900px; }
  .factor {
    margin-bottom: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--gray-100);
  }
  .factor:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .factor img {
    border-radius: var(--radius-lg);
    margin: 20px 0;
  }
  .factor-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 20px;
  }
  .factor-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: 50%;
    background: var(--gray-900);
    color: var(--white);
    font-weight: 800;
    font-size: 1.125rem;
  }
  .fail-num { background: var(--red-500); }
  .factor-header h3 { margin: 0 0 4px; font-size: 1.375rem; }
  .factor-verdict {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 3px 10px;
    border-radius: 100px;
  }
  .verdict-spoton { background: rgba(249,115,22,0.1); color: var(--orange-600); }
  .verdict-halo { background: rgba(59,130,246,0.1); color: var(--blue-600); }
  .verdict-tie { background: rgba(107,114,128,0.1); color: var(--gray-600); }
  .verdict-fail { background: rgba(239,68,68,0.1); color: var(--red-500); }
  .factor-takeaway {
    padding: 20px 24px;
    background: rgba(249,115,22,0.04);
    border-left: 4px solid var(--orange-500);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin-top: 24px;
  }

  /* ====== TEST RESULTS (SpotOn section) ====== */
  .test-results {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 20px 0;
  }
  .test-result {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 16px 20px;
    border-radius: var(--radius-md);
    background: var(--white);
    border: 1px solid var(--gray-200);
  }
  .test-pass { border-left: 3px solid var(--green-500); }
  .test-icon {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--green-500);
    min-width: 24px;
    line-height: 1.4;
  }
  .test-result strong {
    display: block;
    font-size: 0.9375rem;
    margin-bottom: 2px;
  }
  .test-result p {
    font-size: 0.875rem;
    color: var(--gray-500);
    margin: 0;
    line-height: 1.5;
  }

  /* VS Grid */
  .vs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 20px 0;
  }
  .vs-card {
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 20px;
    background: var(--white);
  }
  .vs-card.vs-card-warn {
    border-color: var(--orange-300);
    background: rgba(249,115,22,0.02);
  }
  .vs-card h4 { font-size: 1rem; margin-bottom: 10px; }
  .vs-card ul { padding-left: 1.2rem; margin: 0; }
  .vs-card li { font-size: 0.875rem; margin-bottom: 4px; line-height: 1.5; }
  @media (max-width: 768px) {
    .vs-grid { grid-template-columns: 1fr; }
  }

  /* ====== REAL-WORLD TEST ====== */
  .test-section {
    padding: 64px 0;
    background: var(--off-white);
  }
  .test-section img {
    border-radius: var(--radius-lg);
    margin: 0 0 24px;
  }
  .challenge-list {
    padding-left: 1.5rem;
    margin-bottom: 28px;
  }
  .challenge-list li {
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.7;
    margin-bottom: 4px;
  }
  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 24px;
  }
  .result-card {
    padding: 16px 20px;
    border-radius: var(--radius-md);
    border: 1px solid var(--gray-200);
    background: var(--white);
  }
  .result-card h4 { font-size: 0.9375rem; margin-bottom: 4px; }
  .result-card p { font-size: 0.8125rem; color: var(--gray-500); margin: 0; line-height: 1.5; }
  .result-fail {
    border-color: var(--red-200);
    background: rgba(239,68,68,0.03);
  }
  .result-fail h4::before { content: "\2717 "; color: var(--red-500); }
  .result-ok {
    border-color: var(--orange-200);
    background: rgba(249,115,22,0.03);
  }
  .result-ok h4::before { content: "\26A0 "; }
  .result-winner {
    grid-column: 1 / -1;
    border: 2px solid var(--green-500);
    background: rgba(34,197,94,0.04);
  }
  .result-winner h4::before { content: "\2713 "; color: var(--green-500); }
  @media (max-width: 768px) {
    .results-grid { grid-template-columns: 1fr; }
    .result-winner { grid-column: auto; }
  }

  /* ====== COMPARISON TABLE ====== */
  .table-section {
    padding: 64px 0;
  }
  .cro-table-wrap { overflow-x: auto; }
  .cro-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .cro-table thead th {
    padding: 16px 20px;
    font-size: 0.875rem;
    font-weight: 700;
    text-align: left;
    background: var(--gray-900);
    color: var(--white);
  }
  .cro-table thead th.spoton-col {
    background: var(--orange-600);
  }
  .cro-table tbody td {
    padding: 14px 20px;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--gray-100);
    vertical-align: top;
    line-height: 1.5;
  }
  .cro-table tbody td.spoton-col {
    background: rgba(249, 115, 22, 0.03);
  }
  .cro-table tbody td.feature-col {
    font-weight: 600;
    color: var(--gray-800);
    white-space: nowrap;
  }
  .cro-table tbody tr:last-child td { border-bottom: none; }
  .check { color: var(--green-500); font-weight: 700; margin-right: 4px; }
  .warn { color: var(--orange-500); margin-right: 4px; }
  .x-mark { color: var(--red-500); font-weight: 700; margin-right: 4px; }
  @media (max-width: 768px) {
    .table-section { padding: 40px 0; }
    .cro-table thead th,
    .cro-table tbody td { padding: 10px 12px; font-size: 0.8125rem; }
    .cro-table tbody td.feature-col { white-space: normal; }
  }

  /* ====== COST COMPARISON BARS ====== */
  .investment-section {
    padding: 64px 0;
    background: var(--off-white);
  }
  .cost-compare-grid {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cost-bar {
    display: grid;
    grid-template-columns: 120px 1fr;
    grid-template-rows: auto auto;
    gap: 0 12px;
    align-items: center;
  }
  .cost-bar-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--gray-700);
    grid-row: 1;
  }
  .cost-bar-fill {
    height: 36px;
    background: var(--gray-300);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 12px;
    grid-row: 1;
  }
  .cost-bar-fill span {
    font-weight: 700;
    font-size: 0.8125rem;
    color: var(--white);
  }
  .cost-bar-fill-winner {
    background: linear-gradient(135deg, var(--orange-500), var(--orange-600));
  }
  .cost-bar-sub {
    grid-column: 2;
    grid-row: 2;
    font-size: 0.75rem;
    color: var(--orange-600);
    font-weight: 500;
    margin-top: 2px;
  }
  .cost-bar-sub-winner {
    color: var(--green-600);
  }
  @media (max-width: 768px) {
    .cost-bar { grid-template-columns: 90px 1fr; }
    .cost-bar-label { font-size: 0.8125rem; }
  }

  /* ====== TESTIMONIALS ====== */
  .cro-testimonials {
    padding: 64px 0;
  }
  .cro-testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    max-width: 960px;
    margin: 0 auto;
  }
  .cro-testimonial {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 28px;
  }
  .cro-testimonial-stars {
    color: var(--orange-500);
    font-size: 1.125rem;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .cro-testimonial p {
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 16px;
  }
  .cro-testimonial-author strong {
    display: block;
    font-size: 0.875rem;
    color: var(--gray-800);
  }
  .cro-testimonial-author span {
    font-size: 0.8125rem;
    color: var(--gray-400);
  }
  @media (max-width: 768px) {
    .cro-testimonials { padding: 40px 0; }
    .cro-testimonials-grid { grid-template-columns: 1fr; }
  }

  /* ====== WHO SHOULD CHOOSE ====== */
  .who-section { padding: 64px 0; background: var(--off-white); }
  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 900px;
    margin: 0 auto;
  }
  .who-card {
    border-radius: var(--radius-lg);
    padding: 32px;
  }
  .who-card-spoton {
    border: 2px solid var(--orange-500);
    background: rgba(249,115,22,0.02);
  }
  .who-card-alt {
    border: 1px solid var(--gray-200);
    background: var(--white);
  }
  .who-card h3 { font-size: 1.25rem; margin-bottom: 16px; }
  .who-card ul { list-style: none; padding: 0; margin: 0 0 24px; }
  .who-card li {
    padding: 6px 0 6px 24px;
    position: relative;
    font-size: 0.9375rem;
    color: var(--gray-700);
  }
  .who-card li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    font-weight: 700;
  }
  .who-card-spoton li::before { color: var(--orange-500); }
  .who-card-alt li::before { color: var(--gray-400); }
  @media (max-width: 768px) {
    .who-grid { grid-template-columns: 1fr; }
  }

  /* ====== FAQ ====== */
  .faq-section { padding: 64px 0; }
  .faq-list { display: flex; flex-direction: column; gap: 8px; }
  .faq-item {
    background: var(--off-white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .faq-item summary {
    padding: 18px 24px;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    color: var(--gray-800);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--gray-400);
  }
  .faq-item[open] summary::after { content: "\2212"; }
  .faq-item p {
    padding: 0 24px 18px;
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.7;
    margin: 0;
  }

  /* ====== VERDICT ====== */
  .verdict-section {
    padding: 72px 0;
    background: linear-gradient(135deg, #FFF7ED 0%, var(--white) 100%);
  }
  .verdict-section h2 { font-size: 2rem; margin-bottom: 16px; }
  .verdict-text {
    font-size: 1.0625rem;
    color: var(--gray-600);
    line-height: 1.7;
    max-width: 680px;
    margin: 0 auto 12px;
  }
  .verdict-ctas {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin: 28px 0 16px;
  }
  .verdict-guarantee {
    font-size: 0.8125rem;
    color: var(--gray-400);
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .verdict-section { padding: 48px 0; }
    .verdict-section h2 { font-size: 1.5rem; }
  }

  /* ====== STICKY BOTTOM CTA ====== */
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: var(--white);
    border-top: 1px solid var(--gray-200);
    box-shadow: 0 -4px 16px rgba(0,0,0,0.08);
    padding: 12px 0;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .sticky-cta:hover { color: inherit; }
  .sticky-cta:hover .btn {
    background: linear-gradient(135deg, var(--orange-600), var(--orange-700));
  }
  .sticky-cta.visible { transform: translateY(0); }
  .sticky-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .sticky-cta-text strong {
    display: block;
    font-size: 0.9375rem;
    color: var(--gray-900);
  }
  .sticky-cta-text span {
    font-size: 0.8125rem;
    color: var(--orange-500);
  }
  .sticky-cta .btn { white-space: nowrap; padding: 10px 24px; font-size: 0.875rem; }
  @media (max-width: 768px) {
    .sticky-cta-text strong { font-size: 0.8125rem; }
    .sticky-cta-text span { font-size: 0.75rem; }
    .sticky-cta .btn { padding: 10px 16px; font-size: 0.8125rem; }
  }

  /* ====== CLICKABLE ELEMENTS ====== */
  .product-clickable {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: all var(--transition-base);
  }
  .product-clickable:hover {
    color: inherit;
    box-shadow: 0 12px 40px rgba(249, 115, 22, 0.18);
    transform: translateY(-3px);
  }
  .product-clickable:hover .btn {
    background: linear-gradient(135deg, var(--orange-600), var(--orange-700));
    box-shadow: 0 6px 20px rgba(249, 115, 22, 0.5);
  }
  .inline-cta-clickable {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: all var(--transition-base);
  }
  .inline-cta-clickable:hover {
    color: inherit;
    box-shadow: 0 8px 24px rgba(249, 115, 22, 0.15);
    transform: translateY(-2px);
    border-color: var(--orange-500);
  }
  .inline-cta-clickable:hover .btn {
    background: linear-gradient(135deg, var(--orange-600), var(--orange-700));
    box-shadow: 0 6px 20px rgba(249, 115, 22, 0.5);
  }
  .who-card-clickable {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: all var(--transition-base);
  }
  .who-card-clickable:hover {
    color: inherit;
    box-shadow: 0 12px 40px rgba(249, 115, 22, 0.15);
    transform: translateY(-3px);
  }
  .who-card-clickable:hover .btn {
    background: linear-gradient(135deg, var(--orange-600), var(--orange-700));
    box-shadow: 0 6px 20px rgba(249, 115, 22, 0.5);
  }

  /* ====== EXIT INTENT POPUP ====== */
  .exit-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .exit-overlay.visible {
    opacity: 1;
    visibility: visible;
  }
  .exit-popup {
    background: var(--white);
    border-radius: var(--radius-xl);
    max-width: 480px;
    width: 100%;
    position: relative;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
    transform: scale(0.9) translateY(20px);
    transition: transform 0.3s ease;
    overflow: hidden;
  }
  .exit-overlay.visible .exit-popup {
    transform: scale(1) translateY(0);
  }
  .exit-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 1.75rem;
    color: var(--gray-400);
    cursor: pointer;
    line-height: 1;
    padding: 4px;
    z-index: 1;
    transition: color var(--transition-fast);
  }
  .exit-close:hover { color: var(--gray-700); }
  .exit-content {
    padding: 40px 36px 36px;
    text-align: center;
  }
  .exit-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--orange-500), var(--orange-600));
    color: var(--white);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 5px 16px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }
  .exit-content h2 {
    font-size: 1.625rem;
    line-height: 1.25;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .exit-content > p {
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .exit-features {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .exit-features span {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--green-600);
