---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SpotOn Nova GPS Fence Discount - Save $80 Today" description="Exclusive $80 discount on SpotOn Nova GPS Fence. Verified deal, applies automatically at checkout. 90-day money-back guarantee." ogImage="https://betterthanafence.com/wp-content/uploads/2025/05/SpotOn-Collar-on-Box-Landscape-Crop.jpg">

  <!-- HERO -->
  <section class="discount-hero">
    <div class="container">
      <div class="discount-hero-inner">
        <span class="badge badge-orange">Verified Partner Discount</span>
        <h1>Save $80 on SpotOn Nova</h1>
        <p class="discount-hero-sub">The #1 rated GPS dog fence — now with an exclusive discount that applies automatically at checkout. No coupon codes, no hoops.</p>
        <a href="https://deals.betterthanafence.com/click" class="btn btn-primary btn-lg" data-cta-label="discount-hero" data-cta-brand="spoton" target="_blank" rel="noopener noreferrer nofollow">Claim Your $80 Discount &rarr;</a>
        <div class="hero-meta">
          <span>100% Secure</span>
          <span>&middot;</span>
          <span>Verified Daily</span>
          <span>&middot;</span>
          <span>Official Partner</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICE COMPARISON -->
  <section class="price-section">
    <div class="container">
      <div class="price-cards">
        <div class="price-card">
          <div class="price-card-header">Retail Price</div>
          <div class="price-card-amount">$999</div>
          <div class="price-card-note">Full price at spotonfence.com</div>
        </div>
        <div class="price-card price-card-best">
          <div class="price-card-badge">Best Deal</div>
          <div class="price-card-header">This Offer</div>
          <div class="price-card-amount"><span class="price-old">$999</span> $919</div>
          <div class="price-card-savings">You Save $80</div>
          <a href="https://deals.betterthanafence.com/click" class="btn btn-primary" data-cta-label="discount-price-card" data-cta-brand="spoton" target="_blank" rel="noopener noreferrer nofollow">Get This Price &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section steps-section">
    <div class="container">
      <div class="section-header text-center">
        <h2>3 Steps to Save $80</h2>
      </div>
      <div class="steps-grid">
        <div class="step">
          <div class="step-number">01</div>
          <h3>Click the Button</h3>
          <p>Click any discount button on this page to go to SpotOn's website.</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3>Add to Cart</h3>
          <p>Select your collar size and add SpotOn to your cart.</p>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3>Auto Discount</h3>
          <p>$80 off applies automatically at checkout. No code needed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY SPOTON -->
  <section class="why-section">
    <div class="container">
      <div class="section-header text-center">
        <h2>Why SpotOn Is Our #1 Pick</h2>
        <p class="section-sub">After testing 8+ GPS dog fences over 14 months, SpotOn was the only system we trust.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">&#127919;</div>
          <h3>Under 5 ft Accuracy</h3>
          <p>99.3% containment rate — most accurate GPS boundaries available, even in wooded areas and near buildings.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128274;</div>
          <h3>No Subscription Required</h3>
          <p>Pay once, use forever. Optional tracking plan available but never mandatory.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128225;</div>
          <h3>Works Offline</h3>
          <p>100% off-grid functionality. No cellular connection needed for fencing.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128197;</div>
          <h3>90-Day Guarantee</h3>
          <p>Five Star Guarantee — no-hassle money-back, plus accident forgiveness. Try it risk-free for 3 full months.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#127482;&#127480;</div>
          <h3>Made in USA</h3>
          <p>Designed, developed, and assembled in New Hampshire. Quality you can trust.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128222;</div>
          <h3>Free Trainer Consult</h3>
          <p>30-minute session with a certified trainer included with every purchase.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW SPOTON WORKS -->
  <section class="section how-section">
    <div class="container">
      <div class="section-header text-center">
        <h2>How SpotOn Nova Works</h2>
        <p class="section-sub">No buried wires, no professional installation. Set up your invisible fence in minutes.</p>
      </div>
      <div class="how-grid">
        <div class="how-step">
          <div class="how-step-label">Step 1</div>
          <h3>Download the App</h3>
          <p>Get the SpotOn app on your phone and pair it with the GPS collar via Bluetooth.</p>
        </div>
        <div class="how-step">
          <div class="how-step-label">Step 2</div>
          <h3>Walk Your Boundary</h3>
          <p>Walk the perimeter of your property while the GPS tracks and creates your custom fence.</p>
        </div>
        <div class="how-step">
          <div class="how-step-label">Step 3</div>
          <h3>Fit the Collar</h3>
          <p>Place the GPS collar on your dog. Three strap sizes available (10-26 inch adjustable) for the perfect fit.</p>
        </div>
        <div class="how-step">
          <div class="how-step-label">Step 4</div>
          <h3>Instant Protection</h3>
          <p>Your dog is protected immediately with progressive tone + correction warnings.</p>
        </div>
      </div>
      <div class="how-stats">
        <div class="stat">
          <div class="stat-value">0.33+ Acres</div>
          <div class="stat-label">Minimum Property Size</div>
        </div>
        <div class="stat">
          <div class="stat-value">Unlimited</div>
          <div class="stat-label">Boundary Shapes</div>
        </div>
        <div class="stat">
          <div class="stat-value">~15 min</div>
          <div class="stat-label">Average Setup Time</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section reviews-section">
    <div class="container">
      <div class="section-header text-center">
        <h2>What Dog Owners Say</h2>
        <p class="section-sub">Join thousands of happy customers</p>
      </div>
      <div class="reviews-grid">
        <div class="review-item">
          <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"Best investment for our two Labs! The GPS fence works perfectly on our 5-acre property. Setup was easy and the $80 discount made it a no-brainer."</p>
          <div class="review-meta">
            <strong>Sarah Johnson</strong>
            <span>Austin, TX</span>
          </div>
        </div>
        <div class="review-item">
          <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"We tried other invisible fences but SpotOn is miles ahead. Real-time tracking and the app are game changers. So glad I found this discount!"</p>
          <div class="review-meta">
            <strong>Mike Rodriguez</strong>
            <span>Denver, CO</span>
          </div>
        </div>
        <div class="review-item">
          <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"After months of research, SpotOn was the clear winner. Battery lasts forever and it works in all weather. This discount sealed the deal for us."</p>
          <div class="review-meta">
            <strong>David Thompson</strong>
            <span>Nashville, TN</span>
          </div>
        </div>
      </div>
      <div class="reviews-stats">
        <div class="stat">
          <div class="stat-value">4.8/5</div>
          <div class="stat-label">Average Rating</div>
        </div>
        <div class="stat">
          <div class="stat-value">3,400+</div>
          <div class="stat-label">Happy Customers</div>
        </div>
        <div class="stat">
          <div class="stat-value">98%</div>
          <div class="stat-label">Would Recommend</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container content-width">
      <div class="section-header text-center">
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How do I redeem the $80 discount?</summary>
          <p>Simply click any orange button on this page. You'll be taken to SpotOn's official website where the $80 discount applies automatically at checkout. No coupon code needed.</p>
        </details>
        <details class="faq-item">
          <summary>Is this discount really verified and legitimate?</summary>
          <p>Yes. We're an official SpotOn partner. This discount is verified daily and applies automatically — unlike fake coupon sites with expired codes.</p>
        </details>
        <details class="faq-item">
          <summary>Is there a monthly subscription fee?</summary>
          <p>No. SpotOn Nova's core containment features work without any subscription. There's an optional tracking plan for real-time location monitoring, but it's never required.</p>
        </details>
        <details class="faq-item">
          <summary>What's included in the SpotOn Nova system?</summary>
          <p>You get the GPS collar with 5x larger dual-band antenna, magnetic USB-C charger, quick start guide, and access to the SpotOn app. Plus a free 30-minute consultation with a certified dog trainer.</p>
        </details>
        <details class="faq-item">
          <summary>Does SpotOn work on any property size?</summary>
          <p>SpotOn works on properties from 1/3 acre up to 100,000+ acres. You can create unlimited fence boundaries of virtually any shape.</p>
        </details>
        <details class="faq-item">
          <summary>What's the return policy?</summary>
          <p>SpotOn offers a 90-day Five Star Guarantee — no-hassle money-back, plus accident forgiveness. If you're not satisfied for any reason, return it for a full refund.</p>
        </details>
        <details class="faq-item">
          <summary>Can I use this discount with other offers?</summary>
          <p>This is the best available discount. It applies automatically and cannot be stacked with other promotions.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- BEWARE BANNER -->
  <section class="beware-section">
    <div class="container content-width">
      <div class="beware-card">
        <h3>Beware of Fake Coupon Sites</h3>
        <p>Many coupon aggregator sites list fake or expired SpotOn codes that don't work. We're an official partner with a verified, working discount that's updated daily.</p>
        <div class="beware-checks">
          <span>Official Partner</span>
          <span>Verified Daily</span>
          <span>Actually Works</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta-section">
    <div class="container text-center">
      <h2>Ready to Save $80?</h2>
      <p>Join 3,400+ smart dog owners who chose SpotOn</p>
      <a href="https://deals.betterthanafence.com/click" class="btn btn-primary btn-lg" data-cta-label="final-cta" data-cta-brand="spoton" target="_blank" rel="noopener noreferrer nofollow">Claim My $80 Discount &rarr;</a>
      <div class="final-meta">
        <span>Secure checkout</span>
        <span>&middot;</span>
        <span>No signup required</span>
        <span>&middot;</span>
        <span>Instant savings</span>
      </div>
      <p class="guarantee-note">90-Day Five Star Guarantee &mdash; No-hassle money-back, plus accident forgiveness</p>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .discount-hero {
    padding: 72px 0 64px;
    background: linear-gradient(135deg, #FFF7ED 0%, var(--white) 60%);
    text-align: center;
  }
  .discount-hero-inner { max-width: 680px; margin: 0 auto; }
  .discount-hero h1 {
    font-size: 3rem;
    margin: 16px 0 16px;
    letter-spacing: -0.02em;
  }
  .discount-hero-sub {
    font-size: 1.1875rem;
    color: var(--gray-600);
    line-height: 1.7;
    margin-bottom: 28px;
  }
  .hero-meta {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 16px;
    font-size: 0.8125rem;
    color: var(--gray-400);
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .discount-hero { padding: 48px 0; }
    .discount-hero h1 { font-size: 2rem; }
  }

  /* PRICE CARDS */
  .price-section { padding: 0 0 64px; margin-top: -20px; }
  .price-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 600px;
    margin: 0 auto;
  }
  .price-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 32px;
    text-align: center;
  }
  .price-card-best {
    border: 2px solid var(--orange-500);
    position: relative;
    box-shadow: 0 8px 30px rgba(249, 115, 22, 0.12);
  }
  .price-card-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange-500);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 16px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .price-card-header {
    font-size: 0.875rem;
    color: var(--gray-500);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }
  .price-card-amount {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--gray-900);
  }
  .price-old {
    text-decoration: line-through;
    color: var(--gray-400);
    font-size: 1.5rem;
    font-weight: 500;
    margin-right: 8px;
  }
  .price-card-note { font-size: 0.8125rem; color: var(--gray-400); margin-top: 4px; }
  .price-card-savings {
    color: var(--green-600);
    font-weight: 700;
    font-size: 0.9375rem;
    margin: 4px 0 16px;
  }
  @media (max-width: 768px) {
    .price-cards { grid-template-columns: 1fr; max-width: 320px; }
  }

  /* STEPS */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .step { text-align: center; }
  .step-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--orange-500);
    opacity: 0.3;
    margin-bottom: 8px;
  }
  .step h3 { font-size: 1.125rem; margin-bottom: 8px; }
  .step p { font-size: 0.9375rem; color: var(--gray-500); line-height: 1.6; }
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  /* FEATURES */
  .why-section { padding: 80px 0; background: var(--off-white); }
  .section-sub { color: var(--gray-500); font-size: 1.0625rem; max-width: 560px; margin: 8px auto 0; }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .feature-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 28px;
    text-align: center;
    transition: all var(--transition-base);
  }
  .feature-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .feature-icon { font-size: 2rem; margin-bottom: 12px; }
  .feature-card h3 { font-size: 1rem; margin-bottom: 8px; }
  .feature-card p { font-size: 0.875rem; color: var(--gray-500); line-height: 1.6; }
  @media (max-width: 768px) {
    .why-section { padding: 48px 0; }
    .features-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
  }
  @media (max-width: 480px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  /* HOW IT WORKS */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .how-step { text-align: center; }
  .how-step-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--orange-500);
    margin-bottom: 8px;
  }
  .how-step h3 { font-size: 1rem; margin-bottom: 8px; }
  .how-step p { font-size: 0.875rem; color: var(--gray-500); line-height: 1.6; }
  .how-stats {
    display: flex;
    justify-content: center;
    gap: 64px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--gray-200);
  }
  .stat { text-align: center; }
  .stat-value { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); }
  .stat-label { font-size: 0.8125rem; color: var(--gray-400); margin-top: 4px; }
  @media (max-width: 768px) {
    .how-grid { grid-template-columns: 1fr 1fr; }
    .how-stats { gap: 32px; flex-wrap: wrap; }
  }

  /* REVIEWS */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .review-item {
    background: var(--off-white);
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-lg);
    padding: 28px;
  }
  .review-stars { color: var(--orange-500); font-size: 1.125rem; letter-spacing: 2px; margin-bottom: 12px; }
  .review-item p {
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 16px;
  }
  .review-meta { display: flex; justify-content: space-between; align-items: center; }
  .review-meta strong { font-size: 0.875rem; color: var(--gray-800); }
  .review-meta span { font-size: 0.8125rem; color: var(--gray-400); }
  .reviews-stats {
    display: flex;
    justify-content: center;
    gap: 64px;
    margin-top: 40px;
  }
  @media (max-width: 768px) {
    .reviews-grid { grid-template-columns: 1fr; }
    .reviews-stats { gap: 32px; }
  }

  /* FAQ */
  .faq-section { background: var(--off-white); }
  .faq-list { display: flex; flex-direction: column; gap: 8px; }
  .faq-item {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .faq-item summary {
    padding: 18px 24px;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    color: var(--gray-800);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--gray-400);
    transition: transform var(--transition-base);
  }
  .faq-item[open] summary::after {
    content: "\2212";
  }
  .faq-item p {
    padding: 0 24px 18px;
    font-size: 0.9375rem;
    color: var(--gray-600);
    line-height: 1.7;
  }

  /* BEWARE */
  .beware-section { padding: 48px 0; }
  .beware-card {
    background: #FFFBEB;
    border: 1px solid #FDE68A;
    border-radius: var(--radius-lg);
    padding: 28px 32px;
    text-align: center;
  }
  .beware-card h3 { font-size: 1.125rem; margin-bottom: 8px; }
  .beware-card p { font-size: 0.9375rem; color: var(--gray-600); margin-bottom: 16px; }
  .beware-checks {
    display: flex;
    justify-content: center;
    gap: 24px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--green-600);
  }
  .beware-checks span::before {
    content: "\2713 ";
  }

  /* FINAL CTA */
  .final-cta-section {
    padding: 80px 0;
    background: linear-gradient(135deg, #FFF7ED 0%, var(--white) 100%);
  }
  .final-cta-section h2 { font-size: 2.25rem; margin-bottom: 8px; }
  .final-cta-section > .container > p {
    color: var(--gray-600);
    font-size: 1.0625rem;
    margin-bottom: 24px;
  }
  .final-meta {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 16px;
    font-size: 0.8125rem;
    color: var(--gray-400);
  }
  .guarantee-note {
    margin-top: 16px;
    font-size: 0.8125rem;
    color: var(--gray-400);
    font-weight: 500;
  }
  @media (max-width: 768px) {
    .final-cta-section { padding: 48px 0; }
    .final-cta-section h2 { font-size: 1.75rem; }
  }
</style>
