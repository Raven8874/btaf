<script>
  // Show sticky CTA after scrolling past the hero
  const sticky = document.getElementById('sticky-cta');
  const observer = new IntersectionObserver(
    ([entry]) => {
      if (sticky) {
        sticky.classList.toggle('visible', !entry.isIntersecting);
      }
    },
    { threshold: 0 }
  );
  const hero = document.querySelector('.cro-hero');
  if (hero) observer.observe(hero);

  // Exit intent popup
  const overlay = document.getElementById('exit-overlay');
  const closeBtn = document.getElementById('exit-close');
  const dismissBtn = document.getElementById('exit-dismiss');
  let exitShown = false;

  function showExitPopup() {
    if (exitShown || !overlay) return;
    exitShown = true;
    overlay.classList.add('visible');
    document.body.style.overflow = 'hidden';
  }

  function hideExitPopup() {
    if (!overlay) return;
    overlay.classList.remove('visible');
    document.body.style.overflow = '';
  }

  // Desktop: mouse leaves viewport toward the top
  document.addEventListener('mouseout', (e) => {
    if (e.clientY <= 0 && e.relatedTarget === null) {
      showExitPopup();
    }
  });

  // Mobile fallback: show after 45s of reading if user hasn't clicked a CTA
  let mobileTimer: ReturnType<typeof setTimeout> | null = null;
  if ('ontouchstart' in window) {
    mobileTimer = setTimeout(() => {
      showExitPopup();
    }, 45000);
  }

  // Close handlers
  closeBtn?.addEventListener('click', hideExitPopup);
  dismissBtn?.addEventListener('click', hideExitPopup);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) hideExitPopup();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hideExitPopup();
  });
</script>

