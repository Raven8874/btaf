---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found">
  <section class="error-page">
    <div class="container text-center">
      <h1>404</h1>
      <p>The page you're looking for doesn't exist.</p>
      <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    padding: 120px 0;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .error-page h1 {
    font-size: 5rem;
    color: var(--gray-300);
    margin-bottom: 12px;
  }
  .error-page p {
    font-size: 1.125rem;
    color: var(--gray-500);
    margin-bottom: 28px;
  }
</style>
